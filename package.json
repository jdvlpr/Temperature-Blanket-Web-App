    "canvg": "^4.0.3",
    "chart.js": "^4.5.1",
    "chroma-js": "^3.2.0",
    "getimagepalette": "^2.4.0",
    "globe.gl": "^2.46.1",
    "idb-keyval": "^6.2.5",
    "jspdf": "^4.2.1",
    "node-fetch": "^3.3.2",
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
